# =============================================================================
# Lyosint Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Database ---
# PostgreSQL connection string with pgvector extension
DATABASE_URL=postgres://lyosint:lyosint_dev@localhost:5432/lyosint

# --- Redis ---
# Redis connection string for caching and session management
REDIS_URL=redis://localhost:6379

# --- Authentication ---
# JWT signing secret (change this in production — use a long random string)
JWT_SECRET=change-me-to-a-long-random-secret
# Admin panel credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# --- CORS ---
# Comma-separated list of allowed origins for API requests
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate Limiting ---
# Max requests per window per IP (applied to API routes)
RATE_LIMIT_MAX=100
# Rate limit window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# --- Cache ---
# Cache TTL in seconds for API responses
CACHE_TTL_SECONDS=300
# Max entries in memory cache
CACHE_MAX_ENTRIES=1000

# --- Telegram Integration ---
# Bot token from @BotFather (leave empty to disable)
TELEGRAM_BOT_TOKEN=
# Bot username shown in the UI
VITE_TELEGRAM_BOT_USERNAME=lyosintbot

# JWT refresh secret (change in production)
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret
# AES-256 encryption key (must be exactly 32 characters)
ENCRYPTION_KEY=change-me-to-a-32-char-encryption-key-for-aes-256

# --- Source API Keys (Optional) ---
# These are optional — Lyosint works with public sources out of the box.
# Provide keys here to unlock higher rate limits on specific APIs.

# IntelX / Sherlock / similar OSINT platform keys
INTELX_API_KEY=
# Shodan API key for device discovery
SHODAN_API_KEY=
# HaveIBeenPwned API key for breach checking
HIBP_API_KEY=

# --- Application ---
# Node environment: development | test | production
NODE_ENV=development
# Public-facing URL of the application
PUBLIC_URL=http://localhost:3000
# Server port (default: 3000)
PORT=3000

# --- Docker Compose ---
# PostgreSQL credentials for local Docker setup
POSTGRES_DB=lyosint
POSTGRES_USER=lyosint
POSTGRES_PASSWORD=lyosint_dev
