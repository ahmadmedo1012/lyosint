# ─── API Server (.env at repo root for monorepo) ─────────────────────────────
# Connection string for PostgreSQL (Neon strongly recommended).
# Get it from https://console.neon.tech > Connection Details > Pooled connection
#   postgresql://USER:PASSWORD@ep-xxxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Telegram bot token for user authentication (Telegram Login widget).
# Get from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# Server port (Render sets this automatically; default 10000).
PORT=10000

# Comma-separated list of allowed CORS origins (frontend URL).
# Example: https://lyosint-web.onrender.com
# Use * to allow all (not recommended for production).
CORS_ORIGIN=

# Node environment: development | production
NODE_ENV=production

# ─── Admin (only used until you change credentials via /admin) ───────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ─── Frontend (Vite env vars; only those prefixed with VITE_ are exposed) ────
# Full URL of the API server, e.g. https://lyosint-api.onrender.com
# Leave empty in dev to use the Vite dev-server proxy (relative /api).
VITE_API_URL=
